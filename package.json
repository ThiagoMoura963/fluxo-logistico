{
  "name": "fluxo-logistico",
  "version": "1.0.0",
  "description": "Sistema WEB Mobile-First para gestão operacional logística e programação de cargas.",
  "homepage": "https://github.com/ThiagoMoura963/fluxo-logistico#readme",
  "bugs": {
    "url": "https://github.com/ThiagoMoura963/fluxo-logistico/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThiagoMoura963/fluxo-logistico.git"
  },
  "license": "MIT",
  "author": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up && next dev",
    "test": "npm run services:up && concurrently --names next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand\"",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "prettier:lint:check": "prettier --check .",
    "prettier:lint:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.3",
    "cookie": "1.0.2",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "next": "16.2.6",
    "next-connect": "1.0.0",
    "node-pg-migrate": "7.6.1",
    "pg": "8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "swr": "2.4.1",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@faker-js/faker": "9.7.0",
    "@tailwindcss/postcss": "4.3.0",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "set-cookie-parser": "2.7.1",
    "tailwindcss": "4.3.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
